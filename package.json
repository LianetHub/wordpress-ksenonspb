{
  "name": "ksenonspb-theme",
  "version": "2.0.0",
  "description": "WordPress theme ksenonspb — Gulp-сборка ассетов",
  "main": "gulpfile.js",
  "type": "module",
  "scripts": {
    "dev": "gulp",
    "build": "gulp build --build",
    "zip": "gulp deployZIP --build",
    "deploy:ftp": "gulp ftpDeployAll",
    "test": "vitest run",
    "test:watch": "vitest",
    "parse:sitemap": "node parsing/scripts/01-fetch-sitemap.mjs",
    "parse:scrape": "node parsing/scripts/02-scrape-pages.mjs",
    "parse:lists": "node parsing/scripts/03-build-lists.mjs",
    "parse:all": "npm run parse:sitemap && npm run parse:scrape && npm run parse:lists",
    "import:services": "node parsing/scripts/generate-services-import.mjs",
    "import:categories": "node parsing/scripts/generate-categories-import.mjs",
    "import:brands": "node parsing/scripts/generate-brands-import.mjs",
    "import:portfolio": "node parsing/scripts/generate-portfolio-import.mjs",
    "import:promotions": "node parsing/scripts/generate-promotions-import.mjs"
  },
  "author": "Liana",
  "license": "ISC",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@cursor/sdk": "^1.0.23",
    "@fontsource/inter": "^5.2.8",
    "autoprefixer": "^10.4.21",
    "browser-sync": "^3.0.4",
    "del": "^8.0.1",
    "gulp": "^5.0.1",
    "gulp-autoprefixer": "^10.0.0",
    "gulp-clean-css": "^4.3.0",
    "gulp-cli": "^3.1.0",
    "gulp-fonter": "^0.3.0",
    "gulp-group-css-media-queries": "^1.2.2",
    "gulp-if": "^3.0.0",
    "gulp-imagemin": "^9.2.0",
    "gulp-newer": "^1.4.0",
    "gulp-notify": "^5.0.0",
    "gulp-plumber": "^1.2.1",
    "gulp-rename": "^2.1.0",
    "gulp-replace": "^1.1.4",
    "gulp-sass": "^6.0.1",
    "gulp-shorthand": "^1.1.0",
    "gulp-ttf2woff": "^1.1.1",
    "gulp-ttf2woff2": "^4.0.1",
    "gulp-version-number": "^0.2.4",
    "gulp-webp": "^4.0.1",
    "gulp-webpcss": "^1.1.1",
    "gulp-zip": "^5.1.0",
